# 服务端口（需与前端 vite.config.js 中代理目标一致）
PORT=5001

# 运行环境（development | production | test）
NODE_ENV=development

# MongoDB 连接地址
MONGODB_URI=mongodb://localhost:27017/student-showcase

# JWT 密钥（生产环境必填，建议长度不少于 64 位随机字符串）
JWT_SECRET=please-change-this-to-a-long-random-string-of-at-least-64-characters

# Token 有效期（如 7d / 24h / 3600s）
JWT_EXPIRES_IN=24h

# 允许的前端域名（多个以逗号分隔）
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173
